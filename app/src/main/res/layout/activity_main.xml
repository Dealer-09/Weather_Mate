<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="@drawable/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <RelativeLayout
        android:id="@+id/UI_holder"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <TextView
            android:id="@+id/errorText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Something went wrong"
            android:textSize="28sp"
            android:textColor="#FF5252"
            android:layout_centerInParent="true"
            android:visibility="gone" />

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:visibility="gone"/>


        <TextView
            android:id="@+id/city"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/roboto"
            android:text="Haripal"
            android:textColor="@color/white"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/temperature"
            android:layout_below="@+id/city"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/roboto"
            android:text= "20° C"
            android:textColor="#FFEB3B"
            android:textSize="60sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/cardholder"
            android:padding="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_below="@+id/temperature">

            <androidx.cardview.widget.CardView
                app:cardCornerRadius="10dp"
                android:layout_width="120dp"
                android:layout_height="150dp"
                android:layout_margin="5dp"
                app:cardElevation="5dp"
                android:layout_weight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:layout_marginTop="5dp"
                        android:layout_gravity="center_horizontal"
                        android:src= "@drawable/humidity"/>

                    <TextView
                        android:id="@+id/humidity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" Humidity 50% "
                        android:textSize="15sp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="10dp"
                        android:textStyle="bold"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                app:cardCornerRadius="10dp"
                android:layout_width="120dp"
                android:layout_height="150dp"
                android:layout_margin="5dp"
                app:cardElevation="5dp"
                android:layout_weight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:layout_marginTop="5dp"
                        android:layout_gravity="center_horizontal"
                        android:src= "@drawable/wind"/>

                    <TextView
                        android:id="@+id/Wind"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" Wind Speed: 10kmh "
                        android:textSize="15sp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="10dp"
                        android:textStyle="bold"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/cardholder"
            android:layout_marginTop="5dp"
            android:orientation="vertical"
            android:padding="5dp">

            <ImageView
                android:id="@+id/img_condition"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:src="@drawable/sun__1_"
                android:layout_gravity="center_horizontal"
                />
            <TextView
                android:id="@+id/text_Conditon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sunny"
                android:layout_gravity="center_horizontal"
                android:textColor="@color/white"
                android:textSize="25dp"
                android:layout_marginTop="10dp"/>

            <EditText
                android:id="@+id/edittext_city"
                android:layout_marginTop="10dp"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:textSize="25sp"
                android:hint="Enter Your City"
                android:textColorHint="@color/black"
                android:minHeight="50dp"
                android:background="@drawable/edittext_bg"/>


            <com.google.android.material.button.MaterialButton
                android:id="@+id/Changetext_city"
                android:layout_marginTop="15dp"
                android:layout_gravity="center_horizontal"
                app:icon="@drawable/home"
                app:iconSize="30dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Change City"
                android:textColor="@color/white"
                app:rippleColor="#5BC4F4"
                android:textSize="24sp"
                android:backgroundTint="#3F51B5"
                app:cornerRadius="10dp"/>
        </LinearLayout>


    </RelativeLayout>

</RelativeLayout>